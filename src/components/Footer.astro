---
const currentYear = new Date().getFullYear();
---

<footer class="mx-auto mt-8 w-full max-w-3xl px-4 py-4">
    <div class="flex flex-wrap items-center justify-between gap-3 text-sm">
        <p class="muted">Luiz &copy; 2024-{currentYear}</p>
        <nav class="flex flex-wrap items-center gap-2" aria-label="Links do rodapé">
            <a
                href="https://github.com/ttusk"
                target="_blank"
                rel="noopener noreferrer"
                title="GitHub"
            >
                github
            </a>
            <span aria-hidden="true">/</span>
            <a
                href="/rss.xml"
                target="_blank"
                rel="noopener noreferrer"
                title="RSS Feed"
            >
                rss
            </a>
        </nav>
    </div>
</footer>
