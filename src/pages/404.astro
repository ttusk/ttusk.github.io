---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
    title="404 - Página não encontrada"
    description="Esta página não existe."
>
    <div class="flex flex-col items-center justify-center min-h-[60vh] text-center not-prose ">

        <div class="flex items-center gap-4">
            <div class="text-3xl sm:text-5xl font-bold text-[#dc322f] mb-4">404</div>
            <span class="text-2xl mb-4 text-[#657b83]">σ(￣、￣〃)</span>
        </div>

        <p class="text-sm mb-2 text-[#93a1a1]">
            Essa página infelizmente não existe...
        </p>

        <a
            href="/"
            class="
                text-sm font-semibold
                text-[#586e75]
                hover:text-[#268bd2]
                hover:underline hover:decoration-1 hover:underline-offset-2
            "
        >
            voltar
        </a>
    </div>
</BaseLayout>
