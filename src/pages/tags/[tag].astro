---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const formatDate = (date: Date) =>
    date.toLocaleDateString("pt-BR", {
        day: "2-digit",
        month: "2-digit",
        year: "numeric",
    }).replace(/\//g, "-");

export async function getStaticPaths() {
    const allPosts = await getCollection("posts", ({ data }) => {
        return import.meta.env.PROD ? data.draft !== true : true;
    });

    const uniqueTags = [...new Set(allPosts.flatMap(post => post.data.tags || []))];

    return uniqueTags.map((tag) => {
        const filteredPosts = allPosts
            .filter((post) => post.data.tags?.includes(tag))
            .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

        return {
            params: { tag },
            props: { posts: filteredPosts },
        };
    });
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<BaseLayout title={`Tag: #${tag}`} description={`Posts marcados com ${tag}`}>
    <section class="mt-4 sm:mt-8">
        <h2 class="not-prose text-lg sm:text-xl mb-6 text-[#586e75]">
            <span></span> # {tag}
        </h2>

        {posts.length === 0 ? (
            <div class="not-prose text-center py-12 text-[#93a1a1]">
                <span class="text-2xl block mb-2">(；・∀・)</span>
                <span class="text-sm">nenhum post com essa tag...</span>
            </div>
        ) : (
        <div class="not-prose flex flex-col gap-3 text-xs sm:text-sm">
            {posts.map((post) => (
                <a
                    href={`/${post.id}/`}
                    class="group flex items-baseline gap-2 min-w-0 [text-decoration:none] hover:[text-decoration:none]"
                >
                    <time
                        datetime={post.data.publishDate.toISOString()}
                        class="text-[#93a1a1] whitespace-nowrap shrink-0 tabular-nums"
                    >
                        {formatDate(post.data.publishDate)}
                    </time>
                    <span class="min-w-0 truncate text-[#657b83] group-hover:text-[#586e75]">
                        {post.data.title}
                    </span>
                    {post.data.tags && post.data.tags.length > 0 && (
                        <span class="shrink-0 text-[0.9em] text-[#93a1a1] group-hover:text-[#268bd2]">
                            {post.data.tags.map((tag) => `#${tag}`).join(" ")}
                        </span>
                    )}
                    {post.data.draft && (
                        <span class="text-[#cb4b16] shrink-0">[rascunho]</span>
                    )}
                </a>
            ))}
        </div>
        )}
    </section>
</BaseLayout>
