---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const formatDate = (date: Date) =>
    date.toLocaleDateString("pt-BR", {
        day: "2-digit",
        month: "2-digit",
        year: "numeric",
    });

export async function getStaticPaths() {
    const allPosts = await getCollection("posts", ({ data }) => {
        return import.meta.env.PROD ? data.draft !== true : true;
    });

    const uniqueTags = [...new Set(allPosts.flatMap(post => post.data.tags || []))];

    return uniqueTags.map((tag) => {
        const filteredPosts = allPosts
            .filter((post) => post.data.tags?.includes(tag))
            .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

        return {
            params: { tag },
            props: { posts: filteredPosts },
        };
    });
}

const { tag } = Astro.params;
const { posts } = Astro.props;
const tagClass = (index: number) => `tag-link-${index % 6}`;
---

<BaseLayout title={`Tag: #${tag}`} description={`Posts marcados com ${tag}`}>
    <section class="w-full">
        <div class="mb-8">
            <h1>#{tag}</h1>
        </div>

        {posts.length === 0 ? (
            <div>
                nenhum post com essa tag.
            </div>
        ) : (
            <ul class="space-y-5">
                {posts.map((post) => (
                    <li class="surface-divider border-b pb-4 last:border-b-0">
                        <div>
                            <div class="meta-line">
                                <span>{formatDate(post.data.publishDate)}</span>
                                {post.data.tags && post.data.tags.length > 0 ? (
                                    <>
                                        <span class="meta-dot">•</span>
                                        <div class="flex flex-wrap gap-x-2">
                                            {post.data.tags.map((tag, index) => (
                                                <a href={`/tags/${tag}/`} class={tagClass(index)}>#{tag}</a>
                                            ))}
                                        </div>
                                    </>
                                ) : null}
                            </div>
                            <a href={`/${post.id}/`} class="post-title-link">
                                {post.data.draft && <span class="draft-note">[rascunho] </span>}
                                {post.data.title}
                            </a>
                        </div>
                    </li>
                ))}
            </ul>
        )}
    </section>
</BaseLayout>
