---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const formatDate = (date: Date) =>
    date.toLocaleDateString("pt-BR", {
        day: "2-digit",
        month: "2-digit",
        year: "numeric",
    });

const posts = (await getCollection("posts", ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
})).sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
const tagClass = (index: number) => `tag-link-${index % 6}`;
---

<BaseLayout title="blog" description="meu pedacinho de história na internet">
    <section class="w-full">
        <div class="mb-8">
            <slot />
        </div>

        {posts.length === 0 ? (
            <div>
                nenhum post ainda.
            </div>
        ) : (
            <ul class="space-y-5">
                {posts.map((post) => (
                    <li>
                        <div>
                            <div class="meta-line">
                                <span>{formatDate(post.data.publishDate)}</span>
                                {post.data.tags && post.data.tags.length > 0 ? (
                                    <>
                                        <span class="meta-dot">•</span>
                                        <div class="flex flex-wrap gap-x-2">
                                            {post.data.tags.map((tag, index) => (
                                                <a href={`/tags/${tag}/`} class={tagClass(index)}>#{tag}</a>
                                            ))}
                                        </div>
                                    </>
                                ) : null}
                            </div>
                            <a href={`/${post.id}/`} class="post-title-link">
                                {post.data.draft && <span class="draft-note">[rascunho] </span>}
                                {post.data.title}
                            </a>
                        </div>
                    </li>
                ))}
            </ul>
        )}
    </section>
</BaseLayout>
