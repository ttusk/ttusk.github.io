---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const formatDate = (date: Date) =>
    date.toLocaleDateString("pt-BR", {
        day: "2-digit",
        month: "2-digit",
        year: "numeric",
    }).replace(/\//g, "-");

const posts = (await getCollection("posts", ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
})).sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<BaseLayout title="blog" description="meu pedacinho de história na internet">
    <section>
        <div class="mb-2 sm:mb-4 text-[#657b83]">
            <slot />
        </div>

        {posts.length === 0 ? (
            <div class="not-prose text-center py-12 text-[#93a1a1]">
                <span class="text-2xl block mb-2">(´・ω・`)</span>
                <span class="text-sm">nenhum post ainda...</span>
            </div>
        ) : (
        <div class="not-prose flex flex-col gap-3 text-xs sm:text-sm">
            {posts.map((post) => (
                <a
                    href={`/${post.id}/`}
                    class="group flex items-baseline gap-2 min-w-0 [text-decoration:none] hover:[text-decoration:none]"
                >
                    <time
                        datetime={post.data.publishDate.toISOString()}
                        class="text-[#93a1a1] whitespace-nowrap shrink-0 tabular-nums"
                    >
                        {formatDate(post.data.publishDate)}
                    </time>
                    <span class="min-w-0 truncate text-[#657b83] group-hover:text-[#586e75]">
                        {post.data.title}
                    </span>
                    {post.data.tags && post.data.tags.length > 0 && (
                        <span class="shrink-0 text-[0.9em] text-[#93a1a1] group-hover:text-[#268bd2]">
                            {post.data.tags.map((tag) => `#${tag}`).join(" ")}
                        </span>
                    )}
                    {post.data.draft && (
                        <span class="text-[#cb4b16] shrink-0">[rascunho]</span>
                    )}
                </a>
            ))}
        </div>
        )}
    </section>
</BaseLayout>
