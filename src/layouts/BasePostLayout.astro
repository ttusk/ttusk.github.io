---
import BaseLayout from "./BaseLayout.astro";

const { frontmatter } = Astro.props;

const { title, description, tldr, date, publishDate, tags } = frontmatter || Astro.props;
const createdTime = date ? new Date(date).toISOString() : undefined;
const publishedTime = publishDate ? new Date(publishDate).toISOString() : undefined;
const formatDate = (value: Date | string) =>
    new Date(value).toLocaleDateString("pt-BR", {
        day: "2-digit",
        month: "2-digit",
        year: "numeric",
    }).replace(/\//g, "-");
const shouldShowBothDates = Boolean(
    date &&
    publishDate &&
    new Date(date).getTime() !== new Date(publishDate).getTime(),
);
const postUrl = new URL(Astro.url.pathname, Astro.site).toString();
const articleSchema = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: title,
    description,
    url: postUrl,
    datePublished: publishedTime,
    dateCreated: createdTime,
    dateModified: publishedTime,
    author: {
        "@type": "Person",
        name: "Luiz Gustavo",
        url: Astro.site?.toString(),
    },
    publisher: {
        "@type": "Person",
        name: "Luiz Gustavo",
        url: Astro.site?.toString(),
    },
    mainEntityOfPage: {
        "@type": "WebPage",
        "@id": postUrl,
    },
    keywords: tags,
    inLanguage: "pt-BR",
};
---

<BaseLayout
    title={title}
    description={description}
    ogType="article"
    publishedTime={publishedTime}
    keywords={tags}
>
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <header class="mb-5 sm:mb-10">
        <h1
            class="text-2xl sm:text-3xl font-bold text-[#586e75]"
        >
            {title}
        </h1>

        <div class="mt-1.5 sm:mt-3 text-xs sm:text-sm">
            <div class="flex items-center gap-1.5 text-[#93a1a1] flex-wrap">
                {publishDate && !shouldShowBothDates && (
                    <>
                        <time datetime={new Date(publishDate).toISOString()} class="italic">
                            {formatDate(publishDate)}
                        </time>
                    </>
                )}

                {publishDate && shouldShowBothDates && (
                    <>
                        <span>publicado:</span>
                        <time datetime={new Date(publishDate).toISOString()} class="italic">
                            {formatDate(publishDate)}
                        </time>
                    </>
                )}

                {date && shouldShowBothDates && (
                    <>
                        <span class="text-[#93a1a1]">|</span>
                        <span>criado:</span>
                        <time datetime={new Date(date).toISOString()} class="italic">
                            {formatDate(date)}
                        </time>
                    </>
                )}
            </div>

            {tags && tags.length > 0 && (
                <div class="mt-1 flex gap-2 flex-wrap">
                    {tags.map((tag: string) => (
                        <a
                            href={`/tags/${tag}`}
                            class="
                                text-[#586e75]
                                hover:text-[#268bd2]
                                hover:underline decoration-1 underline-offset-2
                            "
                        >
                            #{tag}
                        </a>
                    ))}
                </div>
            )}
        </div>
    </header>

    {tldr && description && (
        <section class="mb-8 sm:mb-10 -mt-2 sm:-mt-6">
            <h2 class="text-sm text-[#93a1a1]">tldr;</h2>
            <p class="mt-1 text-sm text-[#657b83]">
                {description}
            </p>
        </section>
    )}

    <slot />
</BaseLayout>
