---
import BaseLayout from "./BaseLayout.astro";

const { frontmatter } = Astro.props;

const { title, description, tldr, date, publishDate, tags } = frontmatter || Astro.props;
const createdTime = date ? new Date(date).toISOString() : undefined;
const publishedTime = publishDate ? new Date(publishDate).toISOString() : undefined;
const formatDate = (value: Date | string) =>
    new Date(value).toLocaleDateString("pt-BR", {
        day: "2-digit",
        month: "2-digit",
        year: "numeric",
    }).replace(/\//g, "-");
const shouldShowBothDates = Boolean(
    date &&
    publishDate &&
    new Date(date).getTime() !== new Date(publishDate).getTime(),
);
const postUrl = new URL(Astro.url.pathname, Astro.site).toString();
const articleSchema = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: title,
    description,
    url: postUrl,
    datePublished: publishedTime,
    dateCreated: createdTime,
    dateModified: publishedTime,
    author: {
        "@type": "Person",
        name: "Luiz Gustavo",
        url: Astro.site?.toString(),
    },
    publisher: {
        "@type": "Person",
        name: "Luiz Gustavo",
        url: Astro.site?.toString(),
    },
    mainEntityOfPage: {
        "@type": "WebPage",
        "@id": postUrl,
    },
    keywords: tags,
    inLanguage: "pt-BR",
};
---

<BaseLayout
    title={title}
    description={description}
    ogType="article"
    publishedTime={publishedTime}
    keywords={tags}
>
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <header data-layout="post-header">
        <h1>
            {title}
        </h1>

        <div data-layout="post-meta">
            <div data-layout="post-dates">
                {publishDate && !shouldShowBothDates && (
                    <>
                        <time datetime={new Date(publishDate).toISOString()}>
                            {formatDate(publishDate)}
                        </time>
                    </>
                )}

                {publishDate && shouldShowBothDates && (
                    <>
                        <span>publicado:</span>
                        <time datetime={new Date(publishDate).toISOString()}>
                            {formatDate(publishDate)}
                        </time>
                    </>
                )}

                {date && shouldShowBothDates && (
                    <>
                        <span>|</span>
                        <span>criado:</span>
                        <time datetime={new Date(date).toISOString()}>
                            {formatDate(date)}
                        </time>
                    </>
                )}
            </div>

            {tags && tags.length > 0 && (
                <div data-layout="post-tags">
                    {tags.map((tag: string) => (
                        <a href={`/tags/${tag}`}>
                            <span is-="badge" variant-="blue">#{tag}</span>
                        </a>
                    ))}
                </div>
            )}
        </div>
    </header>

    {tldr && description && (
        <section data-layout="post-summary">
            <h2>tldr;</h2>
            <p>
                {description}
            </p>
        </section>
    )}

    <slot />
</BaseLayout>
