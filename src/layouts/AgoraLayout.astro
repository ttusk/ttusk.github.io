---
import BaseLayout from "@layouts/BaseLayout.astro";
import { experiences } from "@data/experiences";

const { frontmatter = {} } = Astro.props;
const seoTitle = frontmatter.title ?? "agora";
const seoDescription =
    frontmatter.description ??
    "Um pouco sobre mim, minha trajetória e o tipo de trabalho que venho desenvolvendo.";
---

<BaseLayout title={seoTitle} description={seoDescription}>
    <article class="w-full">
        <header class="mb-8">
            <h1>{seoTitle}</h1>
        </header>

        <div class="post-content mb-10">
            <slot />
        </div>

        <section class="mb-10">
            <h2>experiência</h2>
            <section class="code-frame-surface mt-5 overflow-hidden border bg-[color:var(--solarized-base2)]/35">
                <div
                    class="grid w-full gap-0 border-b"
                    style={`grid-template-columns: repeat(${experiences.length}, minmax(0, 1fr));`}
                    role="tablist"
                    aria-label="Experiências"
                >
                    {experiences.map((experience, index) => (
                        <button
                            type="button"
                            class="experience-tab border-r px-3 py-3 text-left text-sm transition-colors last:border-r-0"
                            data-tab-button
                            data-target={experience.id}
                            role="tab"
                            aria-selected={index === 0 ? "true" : "false"}
                            aria-controls={`panel-${experience.id}`}
                            id={`tab-${experience.id}`}
                        >
                            {experience.organization}
                        </button>
                    ))}
                </div>

                <div class="px-5 py-5">
                    {experiences.map((experience, index) => (
                        <section
                            class="experience-panel"
                            data-tab-panel
                            data-panel={experience.id}
                            id={`panel-${experience.id}`}
                            role="tabpanel"
                            aria-labelledby={`tab-${experience.id}`}
                            hidden={index === 0 ? undefined : true}
                        >
                            <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
                                <p class="text-base font-semibold">{experience.title}</p>
                                <span class="meta-line">{experience.period}</span>
                            </div>
                            <ul class="mt-3 list-disc space-y-2 pl-6 leading-7">
                                {experience.bullets.map((bullet) => (
                                    <li>{bullet}</li>
                                ))}
                            </ul>
                        </section>
                    ))}
                </div>
            </section>
        </section>
    </article>
</BaseLayout>

<script>
    const buttons = Array.from(document.querySelectorAll("[data-tab-button]"));
    const panels = Array.from(document.querySelectorAll("[data-tab-panel]"));

    const setActiveTab = (target) => {
        buttons.forEach((button) => {
            const isActive = button.dataset.target === target;
            button.setAttribute("aria-selected", isActive ? "true" : "false");
        });

        panels.forEach((panel) => {
            panel.hidden = panel.dataset.panel !== target;
        });
    };

    if (buttons.length > 0 && panels.length > 0) {
        const initialTarget =
            buttons.find((button) => button.getAttribute("aria-selected") === "true")?.dataset.target ??
            buttons[0]?.dataset.target;

        if (initialTarget) {
            setActiveTab(initialTarget);
        }

        buttons.forEach((button) => {
            button.addEventListener("click", () => {
                if (button.dataset.target) {
                    setActiveTab(button.dataset.target);
                }
            });
        });
    }
</script>
