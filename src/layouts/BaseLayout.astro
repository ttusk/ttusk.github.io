---
import { Font } from "astro:assets";
import "../styles/global.css";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";

const {
    title,
    description,
    canonical = Astro.url,
    ogType = "website",
    publishedTime,
    modifiedTime,
    keywords = [],
} = Astro.props;

const siteName = "talkinghead";
const canonicalUrl = new URL(canonical, Astro.site);
const pageTitle = title ? `${title} | ${siteName}` : siteName;
const keywordContent = Array.isArray(keywords) ? keywords.join(", ") : keywords;
---

<!doctype html>
<html lang="pt-BR">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <Font cssVariable="--font-jetbrains-mono" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <title>{pageTitle}</title>
        <meta name="description" content={description} />
        <meta name="robots" content="index, follow" />
        <link rel="canonical" href={canonicalUrl.toString()} />
        {keywordContent && <meta name="keywords" content={keywordContent} />}

        <meta property="og:site_name" content={siteName} />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content={ogType} />
        <meta property="og:url" content={canonicalUrl.toString()} />

        <meta name="twitter:card" content="summary" />
        <meta name="twitter:title" content={pageTitle} />
        <meta name="twitter:description" content={description} />

        {publishedTime && (
            <meta property="article:published_time" content={publishedTime} />
        )}
        {modifiedTime && (
            <meta property="article:modified_time" content={modifiedTime} />
        )}
    </head>
    <body
        class="min-h-screen max-w-3xl mx-auto px-4
    bg-[#fdf6e3] text-[#657b83]"
    >
        <Header />

        <div class="flex items-center gap-3 my-2 sm:my-4">
            <span
                class="flex-1 border-t sm:border-t-2 border-dashed border-[#93a1a1]"
            ></span>
        </div>

        <main>
            <article
                class="prose max-w-none
                    text-[#657b83]
                    prose-p:text-xs sm:prose-p:text-sm
                    prose-p:leading-relaxed
                    prose-p:hyphens-auto
                    prose-p:text-justify
                    prose-p:break-words
                    prose-p:text-[#657b83]
                    prose-strong:text-[#586e75]
                    prose-headings:font-bold
                    prose-headings:text-[#586e75]
                    prose-h1:text-lg sm:prose-h1:text-2xl prose-h1:my-4
                    prose-h2:text-base sm:prose-h2:text-xl prose-h2:mt-8 prose-h2:my-3
                    prose-h3:text-sm sm:prose-h3:text-lg prose-h3:mt-6 prose-h3:my-2
                    prose-a:font-semibold
                    prose-a:no-underline
                    prose-a:text-[#586e75]
                    [&_a:hover]:underline [&_a:hover]:decoration-1 [&_a:hover]:underline-offset-2
                    [&_a:hover]:text-[#268bd2]
                    prose-pre:!bg-transparent prose-pre:!p-0 prose-pre:!font-normal prose-pre:!border-0 prose-pre:!ring-0
                    prose-code:px-1 prose-code:text-[10px]! sm:prose-code:text-xs!
                    prose-code:text-[#b58900]
                    prose-blockquote:bg-[#eee8d5]
                    prose-blockquote:border-l-4
                    prose-blockquote:border-[#93a1a1]
                    prose-blockquote:italic
                    prose-blockquote:ml-2
                    prose-blockquote:text-[#586e75]
                    prose-img:my-6 prose-img:mx-auto
                    prose-li:text-xs sm:prose-li:text-sm
                    prose-li:text-[#657b83]
                    prose-li:marker:text-[#93a1a1]
                    prose-hr:border-dashed
                    prose-hr:border-[#93a1a1]"
            >
                <slot />
            </article>
        </main>

        <Footer />

        <script
            id="MathJax-script"
            async
            src="https://cdn.jsdelivr.net/npm/mathjax@4/tex-mml-chtml.js"
        ></script>
    </body>
</html>
