---
import { Font } from "astro:assets";
import "../styles/global.css";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";

const {
    title,
    description,
    canonical = Astro.url,
    ogType = "website",
    publishedTime,
    modifiedTime,
    keywords = [],
} = Astro.props;

const siteName = "talkinghead";
const canonicalUrl = new URL(canonical, Astro.site);
const pageTitle = title ? `${title} | ${siteName}` : siteName;
const keywordContent = Array.isArray(keywords) ? keywords.join(", ") : keywords;
---

<!doctype html>
<html lang="pt-BR" data-webtui-theme="solarized-light">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <Font cssVariable="--font-jetbrains-mono" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <title>{pageTitle}</title>
        <meta name="description" content={description} />
        <meta name="robots" content="index, follow" />
        <link rel="canonical" href={canonicalUrl.toString()} />
        {keywordContent && <meta name="keywords" content={keywordContent} />}

        <meta property="og:site_name" content={siteName} />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content={ogType} />
        <meta property="og:url" content={canonicalUrl.toString()} />

        <meta name="twitter:card" content="summary" />
        <meta name="twitter:title" content={pageTitle} />
        <meta name="twitter:description" content={description} />

        {publishedTime && (
            <meta property="article:published_time" content={publishedTime} />
        )}
        {modifiedTime && (
            <meta property="article:modified_time" content={modifiedTime} />
        )}
    </head>
    <body data-layout="page">
        <Header />

        <main data-layout="main">
            <article data-layout="article">
                <slot />
            </article>
        </main>

        <Footer />

        <script
            id="MathJax-script"
            async
            src="https://cdn.jsdelivr.net/npm/mathjax@4/tex-mml-chtml.js"
        ></script>
        <script>
            const vimSelector = '[data-vim-nav], a[href], button, summary, [tabindex]:not([tabindex="-1"])';
            const vimContentSelector = [
                'header[data-layout="site-header"]',
                'footer [data-layout="footer-meta"]',
                '[data-layout="post-index"] > h2',
                '[data-layout="post-dates"] span',
                '[data-layout="post-dates"] time',
                '[data-layout="empty-state"] span',
                'article h1',
                'article h2',
                'article h3',
                'article h4',
                'article h5',
                'article h6',
                'article p',
                'article li',
                'article blockquote',
                'article pre',
                'article img',
                'article table',
                'article hr',
            ].join(', ');

            function isUserTyping() {
                return (
                    document.activeElement &&
                    (/input|textarea|select/i.test(document.activeElement.tagName) ||
                        document.activeElement.hasAttribute('contenteditable'))
                );
            }

            function clearVimActiveState() {
                for (const element of document.querySelectorAll('[data-vim-active]')) {
                    element.removeAttribute('data-vim-active');
                }
            }

            function vimFocusElement(element) {
                element.focus();
                element.scrollIntoView({ block: 'nearest', inline: 'nearest' });
                clearVimActiveState();
                element.setAttribute('data-vim-active', '');
            }

            function prepareVimContentTargets() {
                const targets = document.querySelectorAll(vimContentSelector);

                for (const element of targets) {
                    if (!(element instanceof HTMLElement)) continue;
                    if (element.closest('a, button, summary, pre code, [is-~="badge"], [is-~="button"]')) continue;
                    if (element.matches('[tabindex], a[href], button, summary, [is-~="badge"], [is-~="button"]')) continue;

                    element.setAttribute('tabindex', '0');
                    element.setAttribute('data-vim-nav', '');
                }
            }

            prepareVimContentTargets();

            document.addEventListener('focusin', (event) => {
                const target = event.target instanceof HTMLElement
                    ? event.target.closest(vimSelector)
                    : null;

                if (!target) {
                    clearVimActiveState();
                    return;
                }

                clearVimActiveState();
                target.setAttribute('data-vim-active', '');
            });

            document.addEventListener('click', (event) => {
                const target = event.target instanceof HTMLElement
                    ? event.target.closest(vimSelector)
                    : null;

                if (!target) {
                    clearVimActiveState();
                    return;
                }

                vimFocusElement(target);
            });
        </script>
    </body>
</html>
